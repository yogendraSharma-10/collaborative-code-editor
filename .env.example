# .env.example for Collaborative Code Editor
# Copy this file to .env and fill in the appropriate values for your environment.

# -------------------------------------
# Main Node.js Application (server.js)
# -------------------------------------
# Port for the main Express/WebSocket server
PORT=8080

# Allowed origins for CORS. Use a comma-separated list for multiple origins.
# In production, this should be your frontend's domain.
# Example: http://localhost:3000,https://app.codecollab.com
CORS_ORIGIN=http://localhost:3000

# Secret key for session management and signing JWTs
SESSION_SECRET=a_very_strong_and_long_random_secret_string_for_security

# Environment (development, staging, production)
NODE_ENV=development


# -------------------------------------
# Database & Caching
# -------------------------------------
# Connection string for the primary database (e.g., PostgreSQL, MongoDB)
# Used for storing document metadata, user permissions, etc.
# Example PostgreSQL: postgresql://user:password@localhost:5432/code_editor
# Example MongoDB: mongodb://localhost:27017/code_editor
DATABASE_URL=postgresql://user:password@db:5432/code_editor

# Connection string for Redis.
# Used for WebSocket scaling (pub/sub across multiple instances) and caching.
REDIS_URL=redis://redis:6379


# -------------------------------------
# Python Versioning Microservice (versioning_service/main.py)
# -------------------------------------
# The full base URL for the Python-based versioning service.
# The Node.js server will make API calls to this endpoint.
# In a containerized setup, 'versioning_service' might be the service name.
VERSIONING_SERVICE_URL=http://localhost:5001

# The base directory on the server where Git repositories for each document will be stored.
# Ensure this path is writable by the versioning service user.
GIT_REPO_PATH=/var/data/git_repos

# A shared secret key to secure internal API calls between the Node.js server
# and the Python versioning service. Both services must use the same key.
INTERNAL_API_KEY=replace_with_a_secure_random_string_for_inter_service_auth


# -------------------------------------
# React Frontend Configuration (prefixed with REACT_APP_)
# -------------------------------------
# The full URL for the backend WebSocket server that the client connects to.
# In development, this is often the same as the Node.js server.
REACT_APP_WEBSOCKET_URL=ws://localhost:8080

# The base URL for the backend REST API.
REACT_APP_API_BASE_URL=http://localhost:8080/api


# -------------------------------------
# Inter-Service Communication (Microservice Architecture)
# -------------------------------------
# URL for a centralized Authentication Service (e.g., Keycloak, custom auth service)
# This service would handle user login, registration, and token validation.
AUTH_SERVICE_URL=http://localhost:9000/api/auth

# API endpoint for the Full-Stack Blog Platform
# Used for potential integrations like embedding code snippets from the editor into blog posts.
BLOG_API_URL=http://localhost:4000/api

# API endpoint for the Recipe & Meal Planner service
# Example for demonstrating cross-service communication, e.g., sharing recipe-related code.
RECIPE_API_URL=http://localhost:7000/api